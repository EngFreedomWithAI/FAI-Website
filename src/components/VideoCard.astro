---
interface Props {
  href: string;
  title: string;
  channel: string;
  thumbnailSrc?: string;
  thumbnailAlt?: string;
  featured?: boolean;
}

const {
  href,
  title,
  channel,
  thumbnailSrc,
  thumbnailAlt = '',
  featured = false,
} = Astro.props;
---

<a href={href} class:list={['video-card', featured && 'video-card--featured']}>
  <div class="video-card__thumb">
    {thumbnailSrc ? (
      <img src={thumbnailSrc} alt={thumbnailAlt} loading="lazy" />
    ) : (
      <span class="video-card__play" aria-hidden="true"></span>
    )}
  </div>
  <div class="video-card__body">
    <p class="video-card__title">{title}</p>
    <p class="video-card__channel">{channel}</p>
  </div>
</a>

<style>
  .video-card {
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .video-card:hover {
    transform: translateY(calc(var(--space-1) * -0.75));
    box-shadow: var(--shadow-sm);
    color: inherit;
  }

  .video-card__thumb {
    aspect-ratio: 16 / 9;
    background: linear-gradient(
      135deg,
      var(--color-inverse-surface-2),
      var(--color-inverse-bg)
    );
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
  }

  .video-card--featured .video-card__thumb {
    aspect-ratio: 16 / 10;
  }

  .video-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-card__play {
    width: var(--space-7);
    height: var(--space-7);
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    display: grid;
    place-items: center;
  }

  .video-card__play::after {
    content: '';
    border-left: var(--space-4) solid var(--color-inverse-bg);
    border-top: calc(var(--space-2) + var(--space-1)) solid transparent;
    border-bottom: calc(var(--space-2) + var(--space-1)) solid transparent;
    margin-left: var(--space-1);
  }

  .video-card__body {
    padding: var(--space-4) var(--space-5);
  }

  .video-card__title {
    font-weight: 700;
    font-size: var(--text-md);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .video-card__channel {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }
</style>
