---
import { site } from '../config/site';

interface Props {
  member: 'sonia' | 'cammie';
  alt?: string;
  class?: string;
}

const { member, alt, class: className } = Astro.props;

const labels = {
  sonia: 'Sonia Sarao',
  cammie: 'Cammie Clay',
} as const;
---

<img
  class:list={['team-avatar', className]}
  src={site.teamPhotos[member]}
  alt={alt ?? labels[member]}
  width="400"
  height="400"
  loading="lazy"
  decoding="async"
/>

<style>
  .team-avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1;
  }
</style>
