---
interface Props {
  variant?: 'audience' | 'door' | 'teaser';
  index?: number;
  tag?: string;
  title: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaExternal?: boolean;
  primary?: boolean;
}

const {
  variant = 'audience',
  index,
  tag,
  title,
  body = '',
  ctaLabel,
  ctaHref,
  ctaExternal = false,
  primary = false,
} = Astro.props;

const indexLabel = index !== undefined ? String(index).padStart(2, '0') : undefined;
---

{variant === 'teaser' ? (
  <div class="card-teaser">
    <p class="card-teaser__title">
      {title}
      {tag && <span class="card-teaser__tag"> · {tag}</span>}
    </p>
    {ctaHref && ctaLabel && (
      <a
        href={ctaHref}
        class="card-teaser__link"
        rel={ctaExternal ? 'noopener noreferrer' : undefined}
        target={ctaExternal ? '_blank' : undefined}
      >
        {ctaLabel}
        <span class="card-teaser__arrow" aria-hidden="true">→</span>
      </a>
    )}
  </div>
) : variant === 'door' ? (
  <article class:list={['card-door', primary && 'card-door--primary']}>
    <div class="card-door__top">
      <h3>{title}</h3>
      {tag && <span class="card-door__chip">{tag}</span>}
    </div>
    {body && <p>{body}</p>}
    {ctaHref && ctaLabel && (
      <p class="card-door__cta">
        <a
          href={ctaHref}
          rel={ctaExternal ? 'noopener noreferrer' : undefined}
          target={ctaExternal ? '_blank' : undefined}
        >
          {ctaLabel}
          <span class="card-door__arrow" aria-hidden="true">→</span>
        </a>
      </p>
    )}
  </article>
) : (
  <article class="card-audience">
    {indexLabel && <span class="card-audience__index">{indexLabel}</span>}
    <h3>{title}</h3>
    {body && <p>{body}</p>}
  </article>
)}

<style>
  .card-audience,
  .card-door {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--r-lg);
    padding: var(--space-6);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .card-audience:hover,
  .card-door:hover {
    transform: translateY(calc(var(--space-1) * -0.75));
    box-shadow: var(--shadow-sm);
    border-color: var(--color-border);
  }

  .card-audience__index {
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    font-size: var(--text-sm);
    color: var(--color-accent);
    background: var(--color-accent-soft);
    width: var(--space-7);
    height: var(--space-7);
    border-radius: var(--r-sm);
    display: grid;
    place-items: center;
    margin-bottom: var(--space-4);
  }

  .card-audience h3,
  .card-door h3 {
    font-size: var(--text-lg);
    letter-spacing: -0.015em;
    font-weight: 700;
    line-height: var(--leading-tight);
  }

  .card-audience p,
  .card-door p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-2);
    line-height: var(--leading-relaxed);
  }

  .card-door {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-door--primary {
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
    background: linear-gradient(
        180deg,
        var(--color-accent-soft),
        transparent 60%
      ),
      var(--color-surface);
  }

  .card-door--primary .card-door__chip {
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
    color: var(--color-accent);
  }

  .card-door__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .card-door__top h3 {
    font-size: var(--text-xl);
  }

  .card-door__chip {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--r-lg);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .card-door__cta {
    margin-top: var(--space-2);
  }

  .card-door__cta a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .card-door:not(.card-door--primary) .card-door__cta a {
    color: var(--color-text);
  }

  .card-door__cta a:hover .card-door__arrow {
    transform: translateX(var(--space-1));
  }

  .card-door__arrow {
    display: inline-block;
    transition: transform var(--dur) var(--ease);
  }

  .card-teaser {
    margin-top: var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--r);
    padding: var(--space-4) var(--space-5);
  }

  .card-teaser__title {
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--text-base);
  }

  .card-teaser__tag {
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .card-teaser__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--r);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    transition:
      transform var(--dur-fast) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .card-teaser__link:hover {
    transform: translateY(calc(var(--space-1) * -0.25));
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .card-teaser__arrow {
    transition: transform var(--dur) var(--ease);
  }

  .card-teaser__link:hover .card-teaser__arrow {
    transform: translateX(var(--space-1));
  }
</style>
