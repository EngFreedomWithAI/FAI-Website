---
import type { ContactStageOption } from '../data/contact-form';

interface Props {
  id: string;
  name: string;
  label: string;
  type?: 'text' | 'email' | 'url' | 'textarea' | 'select';
  required?: boolean;
  optional?: boolean;
  rows?: number;
  options?: ContactStageOption[];
  placeholder?: string;
}

const {
  id,
  name,
  label,
  type = 'text',
  required = false,
  optional = false,
  rows = 5,
  options = [],
  placeholder,
} = Astro.props;

const errorId = `${id}-error`;
---

<div class="field" data-field={name}>
  <label class="field__label" for={id}>
    {label}
    {optional && <span class="field__optional"> (optional)</span>}
  </label>

  {
    type === 'textarea' ? (
      <textarea
        id={id}
        name={name}
        rows={rows}
        class="field__control"
        placeholder={placeholder}
        required={required}
        aria-describedby={errorId}
      />
    ) : type === 'select' ? (
      <select
        id={id}
        name={name}
        class="field__control"
        required={required}
        aria-describedby={errorId}
      >
        <option value="" disabled hidden selected>
          Select one
        </option>
        {options.map((option) => (
          <option value={option.value}>{option.label}</option>
        ))}
      </select>
    ) : (
      <input
        id={id}
        name={name}
        type={type}
        class="field__control"
        placeholder={placeholder}
        required={required}
        aria-describedby={errorId}
        autocomplete={type === 'email' ? 'email' : type === 'text' && name === 'name' ? 'name' : undefined}
      />
    )
  }

  <p class="field__error" id={errorId} role="alert" hidden></p>
</div>

<style>
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .field__optional {
    font-weight: 500;
    color: var(--color-text-subtle);
  }

  .field__control {
    width: 100%;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--r);
    padding: var(--space-3) var(--space-4);
    outline: none;
    transition:
      border-color var(--dur-fast) var(--ease),
      box-shadow var(--dur-fast) var(--ease);
  }

  .field__control::placeholder {
    color: var(--color-text-subtle);
  }

  .field__control:focus {
    border-color: var(--color-accent);
    box-shadow: var(--ring-accent);
  }

  .field--invalid .field__control {
    border-color: var(--color-accent-strong);
  }

  .field__error {
    font-size: var(--text-sm);
    color: var(--color-accent-strong);
    margin: 0;
  }

  .field__error:not([hidden]) {
    display: block;
  }

  textarea.field__control {
    resize: vertical;
    min-height: calc(var(--space-9) + var(--space-7));
    line-height: var(--leading-relaxed);
  }
</style>
