---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Field from '../components/Field.astro';
import { contactTopicOptions } from '../data/contact-form';
import '../styles/content-pages.css';

const pageTitle = 'Contact | Freedom with AI';
const pageDescription =
  'Get in touch with Freedom with AI — speaking, events, partnerships, or a general question.';
---

<Base title={pageTitle} description={pageDescription}>
  <Nav />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="contact-heading">
      <div class="container">
        <SectionHeader label="Contact" align="left" />
        <h1 id="contact-heading">Get in touch</h1>
        <p class="page-hero__lede">
          Questions, speaking invitations, events, or partnerships — send a note and we will get back to you.
          Looking to work with us one-on-one? That starts on the
          <a href="/advisory">advisory page</a>.
        </p>

        <div
          id="form-success"
          class="form-banner form-banner--success"
          role="status"
          tabindex="-1"
          hidden
        >
          Thanks for your message. We will get back to you soon.
        </div>

        <div id="form-error" class="form-banner form-banner--error" role="alert" hidden>
          Something went wrong. Please check the fields below and try again.
        </div>

        <form id="contact-form" class="contact-form" novalidate aria-label="Contact us">
          <Field id="contact-name" name="name" label="Name" type="text" required />
          <Field id="contact-email" name="email" label="Email" type="email" required />
          <Field
            id="contact-topic"
            name="topic"
            label="What is this about"
            type="select"
            required
            options={contactTopicOptions}
          />
          <Field
            id="contact-message"
            name="message"
            label="Message"
            type="textarea"
            required
            placeholder="How can we help?"
          />

          <input
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
            class="contact-form__hp"
            aria-hidden="true"
          />

          <Button type="submit" variant="primary" size="large">
            Send message
          </Button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBanner = document.getElementById('form-success');
  const errorBanner = document.getElementById('form-error');

  const fieldLabels: Record<string, string> = {
    name: 'Name',
    email: 'Email',
    topic: 'What is this about',
    message: 'Message',
  };

  const showFieldError = (name: string, message: string) => {
    const wrapper = form?.querySelector(`[data-field="${name}"]`);
    const control = wrapper?.querySelector<HTMLElement>('.field__control');
    const errorEl = wrapper?.querySelector<HTMLElement>('.field__error');
    if (!wrapper || !control || !errorEl) return;
    wrapper.classList.add('field--invalid');
    control.setAttribute('aria-invalid', 'true');
    errorEl.textContent = message;
    errorEl.hidden = false;
  };

  const clearFieldErrors = () => {
    form?.querySelectorAll('[data-field]').forEach((wrapper) => {
      wrapper.classList.remove('field--invalid');
      const control = wrapper.querySelector<HTMLElement>('.field__control');
      const errorEl = wrapper.querySelector<HTMLElement>('.field__error');
      control?.removeAttribute('aria-invalid');
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.hidden = true;
      }
    });
  };

  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  if (form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFieldErrors();
      successBanner?.setAttribute('hidden', '');
      errorBanner?.setAttribute('hidden', '');

      const data = new FormData(form);
      let valid = true;

      const name = String(data.get('name') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const topic = String(data.get('topic') ?? '').trim();
      const message = String(data.get('message') ?? '').trim();

      if (!name) {
        showFieldError('name', `${fieldLabels.name} is required.`);
        valid = false;
      }

      if (!email) {
        showFieldError('email', `${fieldLabels.email} is required.`);
        valid = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFieldError('email', 'Enter a valid email address.');
        valid = false;
      }

      if (!topic) {
        showFieldError('topic', `${fieldLabels.topic} is required.`);
        valid = false;
      }

      if (!message) {
        showFieldError('message', `${fieldLabels.message} is required.`);
        valid = false;
      }

      if (!valid) {
        errorBanner?.removeAttribute('hidden');
        const firstInvalid = form.querySelector<HTMLElement>('.field--invalid .field__control');
        firstInvalid?.focus();
        return;
      }

      const originalLabel = submitButton?.textContent;
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';
      }

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ name, email, topic, message }),
        });
        const result = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error?: string;
          errors?: Record<string, string>;
        };

        if (!res.ok || !result.ok) {
          if (result.errors) {
            for (const [field, msg] of Object.entries(result.errors)) {
              showFieldError(field, msg);
            }
          }
          if (errorBanner) {
            errorBanner.textContent =
              result.error ?? 'Something went wrong. Please check the fields below and try again.';
            errorBanner.removeAttribute('hidden');
          }
          const firstInvalid = form.querySelector<HTMLElement>('.field--invalid .field__control');
          firstInvalid?.focus();
          return;
        }

        form.reset();
        successBanner?.removeAttribute('hidden');
        successBanner?.focus();
      } catch {
        if (errorBanner) {
          errorBanner.textContent = 'We could not reach the server. Please try again in a moment.';
          errorBanner.removeAttribute('hidden');
        }
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = originalLabel ?? 'Send message';
        }
      }
    });

    form.querySelectorAll('.field__control').forEach((control) => {
      control.addEventListener('input', () => {
        const wrapper = control.closest('[data-field]');
        if (!wrapper?.classList.contains('field--invalid')) return;
        wrapper.classList.remove('field--invalid');
        control.removeAttribute('aria-invalid');
        const errorEl = wrapper.querySelector<HTMLElement>('.field__error');
        if (errorEl) {
          errorEl.textContent = '';
          errorEl.hidden = true;
        }
      });
    });
  }
</script>

<style>
  .page-hero .form-banner {
    margin-top: var(--space-5);
    max-width: var(--readw);
  }

  .page-hero .form-banner:focus {
    outline: none;
    box-shadow: var(--ring-accent);
  }

  .contact-form__hp {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0;
    pointer-events: none;
  }
</style>
