---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Field from '../components/Field.astro';
import TeamAvatar from '../components/TeamAvatar.astro';
import { site } from '../config/site';
import { advisoryApproach } from '../data/advisory-engagements';
import { advisoryStageOptions } from '../data/contact-form';
import '../styles/content-pages.css';

const pageTitle = 'Advisory | Freedom with AI';
const pageDescription =
  'Senior advisory for corporate professionals becoming AI entrepreneurs. Paid engagements, deliberately few, each shaped around you.';
---

<Base title={pageTitle} description={pageDescription}>
  <Nav />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="advisory-heading">
      <div class="container profile-split">
        <div class="profile-split__photo">
          <TeamAvatar member="sonia" />
        </div>
        <div class="profile-split__copy">
          <SectionHeader label="Advisory" align="left" />
          <h1 id="advisory-heading">Work with me</h1>
          <p>
            I am Sonia Sarao. I spent a decade as a product executive scaling venture-backed startups. Most
            recently I was VP of Product at Groove, where I helped drive the growth that led to its
            acquisition by Clari. Before that I built a 50-person product and engineering organization and
            helped grow an earlier startup 10x. In mid-2023 I delivered the exit and walked away to build on
            my own terms. Today I build faibuddy, an AI-native product for early founders, entirely myself.
            You get someone who has operated at scale, made the leap you are making, and is still in the
            arena building today, not someone narrating from the sidelines.
          </p>
          <p>
            I work with a small number of corporate professionals becoming AI entrepreneurs, whether you are
            planning your exit, finding your footing after leaving, or pushing through the messy early stage
            of building. This is high-touch, bespoke, and by invitation. Tell me where you are and what you
            are building, and I will reply if it is a fit.
          </p>
          <a
            class="profile-split__link"
            href={site.profiles.soniaLinkedIn}
            target="_blank"
            rel="noopener noreferrer"
          >
            Sonia on LinkedIn <span aria-hidden="true">→</span>
          </a>
          <div class="page-hero__cta">
            <Button variant="primary" href="#request" size="large">
              Request an engagement
            </Button>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section page-section--alt" aria-labelledby="engagements-heading">
      <div class="container">
        <SectionHeader label="How I work" align="left" />
        <h2 id="engagements-heading" class="page-section__heading">
          One partnership, shaped around you
        </h2>
        <p class="page-section__sub">
          There are no packages or fixed deliverables, because no two journeys are the same. Instead there
          is one high-touch partnership with a clear shape, and the work inside it is built around you.
        </p>

        <ul class="engagement-grid">
          {advisoryApproach.map((item) => (
            <li>
              <article class="engagement-card">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            </li>
          ))}
        </ul>

        <p class="page-section__sub page-section__sub--spaced">
          Engagements are paid and kept deliberately few, and we work in seasons, not one-off calls. If you
          want free general advice, our videos and faibuddy are the better place to start.
        </p>
      </div>
    </section>

    <section class="page-section" id="request" aria-labelledby="request-heading">
      <div class="container">
        <SectionHeader label="Request an engagement" align="left" />
        <h2 id="request-heading" class="page-section__heading">Tell me where you are</h2>
        <p class="page-section__sub">
          A few details so I can understand your stage and what you are building. I read every request and
          reply if it is a fit.
        </p>

        <div
          id="form-success"
          class="form-banner form-banner--success"
          role="status"
          tabindex="-1"
          hidden
        >
          Thanks for reaching out. I read every message and reply if it is a fit.
        </div>

        <div id="form-error" class="form-banner form-banner--error" role="alert" hidden>
          Something went wrong. Please check the fields below and try again.
        </div>

        <form id="request-form" class="contact-form" novalidate aria-label="Request an engagement">
          <Field id="advisory-name" name="name" label="Name" type="text" required />
          <Field id="advisory-email" name="email" label="Email" type="email" required />
          <Field
            id="advisory-stage"
            name="stage"
            label="Which best describes you"
            type="select"
            required
            options={advisoryStageOptions}
          />
          <Field
            id="advisory-message"
            name="message"
            label="What do you want to be different in 90 days, and why now"
            type="textarea"
            required
            placeholder="A few sentences on where you are, what you want to build, and why this is the moment."
          />
          <Field
            id="advisory-link"
            name="link"
            label="LinkedIn or what you are building"
            type="url"
            optional
            placeholder="https://"
          />

          <input
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
            class="contact-form__hp"
            aria-hidden="true"
          />

          <Button type="submit" variant="primary" size="large">
            Send request
          </Button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  const form = document.getElementById('request-form') as HTMLFormElement | null;
  const successBanner = document.getElementById('form-success');
  const errorBanner = document.getElementById('form-error');

  const fieldLabels: Record<string, string> = {
    name: 'Name',
    email: 'Email',
    stage: 'Which best describes you',
    message: 'What do you want to be different in 90 days, and why now',
    link: 'LinkedIn or what you are building',
  };

  const showFieldError = (name: string, message: string) => {
    const wrapper = form?.querySelector(`[data-field="${name}"]`);
    const control = wrapper?.querySelector<HTMLElement>('.field__control');
    const errorEl = wrapper?.querySelector<HTMLElement>('.field__error');
    if (!wrapper || !control || !errorEl) return;
    wrapper.classList.add('field--invalid');
    control.setAttribute('aria-invalid', 'true');
    errorEl.textContent = message;
    errorEl.hidden = false;
  };

  const clearFieldErrors = () => {
    form?.querySelectorAll('[data-field]').forEach((wrapper) => {
      wrapper.classList.remove('field--invalid');
      const control = wrapper.querySelector<HTMLElement>('.field__control');
      const errorEl = wrapper.querySelector<HTMLElement>('.field__error');
      control?.removeAttribute('aria-invalid');
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.hidden = true;
      }
    });
  };

  const isValidUrl = (value: string) => {
    if (!value.trim()) return true;
    try {
      const url = new URL(value);
      return url.protocol === 'http:' || url.protocol === 'https:';
    } catch {
      return false;
    }
  };

  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  if (form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFieldErrors();
      successBanner?.setAttribute('hidden', '');
      errorBanner?.setAttribute('hidden', '');

      const data = new FormData(form);
      let valid = true;

      const name = String(data.get('name') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const stage = String(data.get('stage') ?? '').trim();
      const message = String(data.get('message') ?? '').trim();
      const link = String(data.get('link') ?? '').trim();

      if (!name) {
        showFieldError('name', `${fieldLabels.name} is required.`);
        valid = false;
      }

      if (!email) {
        showFieldError('email', `${fieldLabels.email} is required.`);
        valid = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFieldError('email', 'Enter a valid email address.');
        valid = false;
      }

      if (!stage) {
        showFieldError('stage', `${fieldLabels.stage} is required.`);
        valid = false;
      }

      if (!message) {
        showFieldError('message', `${fieldLabels.message} is required.`);
        valid = false;
      }

      if (link && !isValidUrl(link)) {
        showFieldError('link', 'Enter a valid link starting with http:// or https://.');
        valid = false;
      }

      if (!valid) {
        errorBanner?.removeAttribute('hidden');
        const firstInvalid = form.querySelector<HTMLElement>('.field--invalid .field__control');
        firstInvalid?.focus();
        return;
      }

      const originalLabel = submitButton?.textContent;
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';
      }

      try {
        const res = await fetch('/api/advisory', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ name, email, stage, message, link }),
        });
        const result = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error?: string;
          errors?: Record<string, string>;
        };

        if (!res.ok || !result.ok) {
          if (result.errors) {
            for (const [field, msg] of Object.entries(result.errors)) {
              showFieldError(field, msg);
            }
          }
          if (errorBanner) {
            errorBanner.textContent =
              result.error ?? 'Something went wrong. Please check the fields below and try again.';
            errorBanner.removeAttribute('hidden');
          }
          const firstInvalid = form.querySelector<HTMLElement>('.field--invalid .field__control');
          firstInvalid?.focus();
          return;
        }

        form.reset();
        successBanner?.removeAttribute('hidden');
        successBanner?.focus();
      } catch {
        if (errorBanner) {
          errorBanner.textContent = 'We could not reach the server. Please try again in a moment.';
          errorBanner.removeAttribute('hidden');
        }
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = originalLabel ?? 'Send request';
        }
      }
    });

    form.querySelectorAll('.field__control').forEach((control) => {
      control.addEventListener('input', () => {
        const wrapper = control.closest('[data-field]');
        if (!wrapper?.classList.contains('field--invalid')) return;
        wrapper.classList.remove('field--invalid');
        control.removeAttribute('aria-invalid');
        const errorEl = wrapper.querySelector<HTMLElement>('.field__error');
        if (errorEl) {
          errorEl.textContent = '';
          errorEl.hidden = true;
        }
      });
    });
  }
</script>

<style>
  .page-section .form-banner {
    margin-top: var(--space-5);
    max-width: var(--readw);
  }

  .page-section .form-banner:focus {
    outline: none;
    box-shadow: var(--ring-accent);
  }

  .contact-form__hp {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0;
    pointer-events: none;
  }
</style>
