---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Field from '../components/Field.astro';
import TeamAvatar from '../components/TeamAvatar.astro';
import { site } from '../config/site';
import { advisoryStageOptions } from '../data/contact-form';
import '../styles/content-pages.css';

const pageTitle = 'Advisory | Freedom with AI';
const pageDescription =
  'Fractional co-founder advisory for founders who have left, or are about to. Two AI-native co-founders building with you from idea to first customers. Paid, deliberately few.';
---

<Base title={pageTitle} description={pageDescription}>
  <Nav />

  <main id="main-content">
    <section class="page-hero page-hero--center" aria-labelledby="advisory-heading">
      <div class="container">
        <SectionHeader label="Fractional co-founder advisory" />
        <h1 id="advisory-heading" class="page-hero__title">
          The full arc. Idea to first customers.
        </h1>
        <p class="page-hero__lede">
          Validation. Positioning. The build. The path to revenue. We work it with you, adapted to where you
          actually are.
        </p>
        <div class="page-hero__cta page-hero__cta--center">
          <Button variant="primary" href="#request" size="large">
            Request an engagement
          </Button>
        </div>
        <p class="page-hero__micro">
          Hands-on, outcome-focused, all in. We win when you win.
        </p>
      </div>
    </section>

    <section class="page-section page-section--alt" aria-labelledby="who-heading">
      <div class="container">
        <SectionHeader label="Who this is for" align="left" />
        <h2 id="who-heading" class="page-section__heading">You've made the leap. Or you're about to.</h2>
        <p class="page-section__sub">
          You want partners who've done it. Who'll tell you the truth. Who'll do the hard parts with you. We
          meet you where you are:
        </p>

        <ul class="lede-list">
          <li>
            <span class="lede-list__lead">Planning your exit</span>
            <span class="lede-list__body">Line up the leap so day one is a business, not a blank page.</span>
          </li>
          <li>
            <span class="lede-list__lead">Just left, finding your footing</span>
            <span class="lede-list__body">Turn the leap into a business that actually pays.</span>
          </li>
          <li>
            <span class="lede-list__lead">Building, but stuck</span>
            <span class="lede-list__body">Get a sharper path and an honest second brain in your corner.</span>
          </li>
          <li>
            <span class="lede-list__lead">Have traction, need leverage</span>
            <span class="lede-list__body">
              Add fractional technical and go-to-market firepower to move faster.
            </span>
          </li>
        </ul>
      </div>
    </section>

    <section class="page-section" aria-label="Your advisors">
      <div class="container">
        <SectionHeader label="Your advisors" align="left" />
        <p class="page-section__sub">
          We're both AI-native. We run our business on AI, we build our own AI product,
          <a href={site.faibuddyUrl} target="_blank" rel="noopener noreferrer">faibuddy</a>, and we help you
          leverage it for your venture.
        </p>

        <div class="founder-grid">
          <article class="founder-card">
            <div class="founder-card__photo">
              <TeamAvatar member="sonia" />
            </div>
            <h3>Sonia Sarao</h3>
            <p class="founder-card__role">Product + Technical Advisor</p>
            <p>
              Product and engineering executive who has led teams through growth and a successful exit. She
              now builds <a href={site.faibuddyUrl} target="_blank" rel="noopener noreferrer">faibuddy</a>
              hands-on with AI and brings sharp technical judgment and strong product
              instinct to every advisory engagement. She cuts through complexity fast. Whether she's building
              with you, guiding your team, or helping you choose the right AI tools, her focus is always the
              same: get to real value quickly without wasting time or money on the wrong path.
            </p>
            <a href={site.profiles.soniaLinkedIn} target="_blank" rel="noopener noreferrer">
              Sonia on LinkedIn <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="founder-card">
            <div class="founder-card__photo">
              <TeamAvatar member="cammie" />
            </div>
            <h3>Cammie Clay</h3>
            <p class="founder-card__role">Customer Discovery + GTM Advisor</p>
            <p>
              High-stakes finance turned go-to-market operator and serious AI practitioner. She brings
              customer signal, positioning clarity, and the relentless push that turns motion into traction.
              She makes the hard parts feel doable, and won't let you avoid the work that creates real
              momentum.
            </p>
            <a href={site.profiles.cammieLinkedIn} target="_blank" rel="noopener noreferrer">
              Cammie on LinkedIn <span aria-hidden="true">→</span>
            </a>
          </article>
        </div>
      </div>
    </section>

    <section class="page-section page-section--alt" aria-labelledby="work-heading">
      <div class="container work-split">
        <div class="work-split__main">
          <SectionHeader label="How we work" align="left" />
          <h2 id="work-heading" class="page-section__heading">First chapter, then partnership</h2>
          <p class="page-section__sub">
            Every engagement is unique, so there's no fixed package. We start with a focused first chapter: a
            defined opening phase on whatever matters most right now. Prove fit, build momentum, and grow into
            an ongoing partnership from there.
          </p>

          <p class="rhythm-label">What stays constant</p>
          <ul class="check-list">
            <li>Close to the work, not a monthly check-in</li>
            <li>Accountability both ways</li>
            <li>Momentum you can feel</li>
          </ul>
        </div>

        <aside class="fit-card">
          <h3 class="fit-card__title">Is this a fit?</h3>
          <p>
            A dual commitment: we go all in, so do you. Engagements are paid and deliberately few, a handful
            of founders at a time.
          </p>
          <p>
            This is for you if you're serious and ready to do the work: show up, make the calls, ship the
            thing.
          </p>
          <Button variant="primary" href="#request" size="large">
            Request an engagement
          </Button>
          <p class="fit-card__note">
            Prefer to move at your own pace first? Start with
            <a href={site.faibuddyUrl} target="_blank" rel="noopener noreferrer">faibuddy</a>, our AI
            product, and bring us in when you're ready.
          </p>
        </aside>
      </div>
    </section>

    <section class="page-section" id="request" aria-labelledby="request-heading">
      <div class="container">
        <SectionHeader label="Request an engagement" align="left" />
        <h2 id="request-heading" class="page-section__heading">Tell us where you are</h2>
        <p class="page-section__sub">
          A few details so we can understand your stage and what you are building. We read every request and
          reply if it is a fit.
        </p>

        <div
          id="form-success"
          class="form-banner form-banner--success"
          role="status"
          tabindex="-1"
          hidden
        >
          Thanks for reaching out. We read every message and reply if it is a fit.
        </div>

        <div id="form-error" class="form-banner form-banner--error" role="alert" hidden>
          Something went wrong. Please check the fields below and try again.
        </div>

        <form id="request-form" class="contact-form" novalidate aria-label="Request an engagement">
          <Field id="advisory-name" name="name" label="Name" type="text" required />
          <Field id="advisory-email" name="email" label="Email" type="email" required />
          <Field
            id="advisory-stage"
            name="stage"
            label="Which best describes you"
            type="select"
            required
            options={advisoryStageOptions}
          />
          <Field
            id="advisory-message"
            name="message"
            label="What do you want to be different in 90 days, and why now"
            type="textarea"
            required
            placeholder="A few sentences on where you are, what you want to build, and why this is the moment."
          />
          <Field
            id="advisory-link"
            name="link"
            label="LinkedIn or what you are building"
            type="url"
            optional
            placeholder="https://"
          />

          <input
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
            class="contact-form__hp"
            aria-hidden="true"
          />

          <Button type="submit" variant="primary" size="large">
            Send request
          </Button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  const form = document.getElementById('request-form') as HTMLFormElement | null;
  const successBanner = document.getElementById('form-success');
  const errorBanner = document.getElementById('form-error');

  const fieldLabels: Record<string, string> = {
    name: 'Name',
    email: 'Email',
    stage: 'Which best describes you',
    message: 'What do you want to be different in 90 days, and why now',
    link: 'LinkedIn or what you are building',
  };

  const showFieldError = (name: string, message: string) => {
    const wrapper = form?.querySelector(`[data-field="${name}"]`);
    const control = wrapper?.querySelector<HTMLElement>('.field__control');
    const errorEl = wrapper?.querySelector<HTMLElement>('.field__error');
    if (!wrapper || !control || !errorEl) return;
    wrapper.classList.add('field--invalid');
    control.setAttribute('aria-invalid', 'true');
    errorEl.textContent = message;
    errorEl.hidden = false;
  };

  const clearFieldErrors = () => {
    form?.querySelectorAll('[data-field]').forEach((wrapper) => {
      wrapper.classList.remove('field--invalid');
      const control = wrapper.querySelector<HTMLElement>('.field__control');
      const errorEl = wrapper.querySelector<HTMLElement>('.field__error');
      control?.removeAttribute('aria-invalid');
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.hidden = true;
      }
    });
  };

  const isValidUrl = (value: string) => {
    if (!value.trim()) return true;
    try {
      const url = new URL(value);
      return url.protocol === 'http:' || url.protocol === 'https:';
    } catch {
      return false;
    }
  };

  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  if (form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFieldErrors();
      successBanner?.setAttribute('hidden', '');
      errorBanner?.setAttribute('hidden', '');

      const data = new FormData(form);
      let valid = true;

      const name = String(data.get('name') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const stage = String(data.get('stage') ?? '').trim();
      const message = String(data.get('message') ?? '').trim();
      const link = String(data.get('link') ?? '').trim();

      if (!name) {
        showFieldError('name', `${fieldLabels.name} is required.`);
        valid = false;
      }

      if (!email) {
        showFieldError('email', `${fieldLabels.email} is required.`);
        valid = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFieldError('email', 'Enter a valid email address.');
        valid = false;
      }

      if (!stage) {
        showFieldError('stage', `${fieldLabels.stage} is required.`);
        valid = false;
      }

      if (!message) {
        showFieldError('message', `${fieldLabels.message} is required.`);
        valid = false;
      }

      if (link && !isValidUrl(link)) {
        showFieldError('link', 'Enter a valid link starting with http:// or https://.');
        valid = false;
      }

      if (!valid) {
        errorBanner?.removeAttribute('hidden');
        const firstInvalid = form.querySelector<HTMLElement>('.field--invalid .field__control');
        firstInvalid?.focus();
        return;
      }

      const originalLabel = submitButton?.textContent;
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';
      }

      try {
        const res = await fetch('/api/advisory', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ name, email, stage, message, link }),
        });
        const result = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error?: string;
          errors?: Record<string, string>;
        };

        if (!res.ok || !result.ok) {
          if (result.errors) {
            for (const [field, msg] of Object.entries(result.errors)) {
              showFieldError(field, msg);
            }
          }
          if (errorBanner) {
            errorBanner.textContent =
              result.error ?? 'Something went wrong. Please check the fields below and try again.';
            errorBanner.removeAttribute('hidden');
          }
          const firstInvalid = form.querySelector<HTMLElement>('.field--invalid .field__control');
          firstInvalid?.focus();
          return;
        }

        form.reset();
        successBanner?.removeAttribute('hidden');
        successBanner?.focus();
      } catch {
        if (errorBanner) {
          errorBanner.textContent = 'We could not reach the server. Please try again in a moment.';
          errorBanner.removeAttribute('hidden');
        }
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = originalLabel ?? 'Send request';
        }
      }
    });

    form.querySelectorAll('.field__control').forEach((control) => {
      control.addEventListener('input', () => {
        const wrapper = control.closest('[data-field]');
        if (!wrapper?.classList.contains('field--invalid')) return;
        wrapper.classList.remove('field--invalid');
        control.removeAttribute('aria-invalid');
        const errorEl = wrapper.querySelector<HTMLElement>('.field__error');
        if (errorEl) {
          errorEl.textContent = '';
          errorEl.hidden = true;
        }
      });
    });
  }
</script>

<style>
  .page-hero__cta--center {
    justify-content: center;
  }

  .page-hero__micro {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .founder-card__role {
    margin-top: var(--space-2) !important;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
  }

  .lede-list {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: grid;
    gap: var(--space-4);
    max-width: var(--readw);
  }

  .lede-list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-accent);
  }

  .lede-list__lead {
    font-weight: 700;
    color: var(--color-text);
  }

  .lede-list__body {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3) var(--space-5);
    max-width: var(--readw);
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-5);
    font-size: var(--text-md);
    color: var(--color-text);
    line-height: var(--leading-relaxed);
  }

  .check-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .rhythm-label {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .work-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 23rem);
    gap: var(--space-7);
    align-items: start;
  }

  .fit-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--r-lg);
    padding: var(--space-6);
  }

  .fit-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .fit-card p {
    margin-top: var(--space-3);
    font-size: var(--text-md);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .fit-card .btn {
    margin-top: var(--space-5);
  }

  .fit-card__note {
    margin-top: var(--space-4) !important;
    font-size: var(--text-sm) !important;
    color: var(--color-text-subtle) !important;
  }

  @media (max-width: 55rem) {
    .work-split {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 40rem) {
    .check-list {
      grid-template-columns: 1fr;
    }
  }

  .page-section .form-banner {
    margin-top: var(--space-5);
    max-width: var(--readw);
  }

  .page-section .form-banner:focus {
    outline: none;
    box-shadow: var(--ring-accent);
  }

  .contact-form__hp {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0;
    pointer-events: none;
  }
</style>
