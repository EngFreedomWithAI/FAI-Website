---
import '../styles/tokens.css';
import '../styles/global.css';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = `${site.brand} | Corporate to AI Entrepreneur`,
  description = `${site.mission} Start with faibuddy today, and work with us when you want a guide.`,
  image = '/images/og-default.png',
  schema,
} = Astro.props;

const siteOrigin = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const imageURL = new URL(image, siteOrigin);
const ogImageAlt = `${site.brand}. Corporate to AI Entrepreneur.`;
const origin = new URL(siteOrigin).origin;

const organizationSchema = {
  '@type': 'Organization',
  '@id': `${origin}/#organization`,
  name: site.brand,
  url: `${origin}/`,
  logo: new URL('/images/logo.svg', origin).href,
  description: site.mission,
  sameAs: [site.socials.youtube, site.socials.x],
  founder: [
    { '@type': 'Person', name: 'Sonia Sarao', sameAs: site.profiles.soniaLinkedIn },
    { '@type': 'Person', name: 'Cammie Clay', sameAs: site.profiles.cammieLinkedIn },
  ],
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${origin}/#website`,
  name: site.brand,
  url: `${origin}/`,
  description,
  publisher: { '@id': `${origin}/#organization` },
};

const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [organizationSchema, websiteSchema, ...pageSchemas],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <link rel="icon" href="/images/logo.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
