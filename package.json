{
  "name": "fai-website",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "astro build",
    "preview": "astro preview",
    "cf:dev": "wrangler pages dev dist",
    "db:create": "wrangler d1 create fai-website-db",
    "db:migrate": "wrangler d1 execute fai-website-db --remote --file=./migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute fai-website-db --local --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "astro": "^5.7.0",
    "aws4fetch": "^1.0.20"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250606.0",
    "wrangler": "^4.20.0"
  }
}
